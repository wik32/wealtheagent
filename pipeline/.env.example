# Kopieren nach .env und ausfüllen, sobald die AWS-Zugangsdaten vorliegen.
# .env wird automatisch von cli/eval/check-claude geladen und ist git-ignoriert.

# AWS-Zugangsdaten (IAM-User oder temporäre Credentials)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Nur bei temporären Credentials nötig:
# AWS_SESSION_TOKEN=

# EU-Region (Frankfurt). Nicht ändern, außer bewusst gewollt.
AWS_REGION=eu-central-1

# Optionale Modell-Overrides (Default: EU-regionale IDs, siehe README)
# FINANZAPP_CLASSIFY_MODEL=eu.anthropic.claude-haiku-4-5-20251001-v1:0
# FINANZAPP_EXTRACT_MODEL=eu.anthropic.claude-opus-4-6-v1

# Optional, für den Mistral-Adapter (Sprint 2)
# MISTRAL_API_KEY=
